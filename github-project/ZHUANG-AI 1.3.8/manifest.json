{
  "manifestVersion": 5,
  "id": "com.zhuang.ai.retouch",
  "name": "ZHUANG-AI 修图插件",
  "version": "1.3.8",
  "main": "index.html",
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark"],
      "species": ["generic"]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ],
  "host": {
    "app": "PS",
    "minVersion": "26.0.0",
    "platform": ["win", "mac"]
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "fullAccess"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "zhuangAiPanel",
      "label": "ZHUANG-AI 修图插件",
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ],
      "minimumSize": {
        "width": 320,
        "height": 400
      },
      "maximumSize": {
        "width": 800,
        "height": 3000
      },
      "preferredDockedSize": {
        "width": 420,
        "height": 900
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 900
      }
    }
  ]
}
